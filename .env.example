# 环境变量配置示例
# 复制此文件为 .env 并修改配置

# 数据库配置
DB_ROOT_PASSWORD=root123456
DB_USER=community
DB_PASS=lls123456

# Redis 配置
REDIS_PASS=your_redis_password_here

# JWT 密钥 (生产环境请使用强密钥)
JWT_SECRET=your-256-bit-secret-key-change-in-production

# 前端 API 基址
# 通过 Nginx 反代访问时可以留空；如果单独跑前端开发服务器，可设置为 http://localhost:8080
# NUXT_PUBLIC_API_BASE=

# 阿里云 OSS 配置
OSS_ACCESS_KEY_ID=your_access_key_id_here
OSS_ACCESS_KEY_SECRET=your_access_key_secret_here
OSS_BUCKET_NAME=your_bucket_name
OSS_ENDPOINT=oss-cn-beijing.aliyuncs.com
